    "version": "0.2.0",
    "configurations": [
         {
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "ignore": [
                "**/vendor/**",
                "**/utm/**"
            ]

        },
        {
            "name": "Profile Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/home/bjorn/www/public_html/plex_web": "${workspaceRoot}"
            },
            "noDebug": true,
            "profile": true
        }
    ]
}
