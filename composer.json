{
    "autoload": {
        "exclude-from-classmap": [
            "vendor/symfony/console/Formatter/OutputFormatter.php",
            "vendor/jbzoo/cli/src/CliApplication.php"


        ],
        "psr-4": {
            "Mediatag\\": "app",
            "Formatter\\": "app/Overrides/"
        },
        "classmap": [
            "app"        ]
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.67",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "require": {
        "symfony/console": "^8.0",
        "bhittani/download": "^0.3.0",
        "symfony/monolog-bundle": "^3.8",
        "symfony/config": "7.0.*",
        "nette/utils": "^4.1",
        "php-di/php-di": "^7.0",
        "slim/slim": "^4.11",
        "slim/psr7": "^1.6",
        "camoo/config": "^1.0",
        "vlucas/phpdotenv": "^5.5",
        "siteorigin/string-splitter": "^1.0",
        "intervention/image": "^3.3",
        "nesbot/carbon": "^3.6",
        "bsodergren/utm": "^2.1",
        "symfony/http-client": "^7.3",
        "psr/log": "^3.0",
        "evenement/evenement": "^3.0",
        "paramako/pornhub-api-client": "^1.0",
        "tracy/tracy": "^2.10",
        "carbon-cli/carbon-cli": "^1.3",
        "nette/di": "^3.2",
        "nette/php-generator": "^4.2",
        "nikic/php-parser": "^5.7",
        "symfony/finder": "^7.4",
        "symfony/process": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.10",
        "symfony/runtime": "^8.0",
        "jbzoo/cli": "^7.2",
        "fakerphp/faker": "^1.24",
        "php-ffmpeg/php-ffmpeg": "^1.4",
        "mhor/php-mediainfo": "^5.8",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/migrations": "^3.9"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd"
        }
    },
    "bin": [
        "mediaclitest"
    ]
}
